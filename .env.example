# Copy to .env and fill in values

# ── Provider: Claude (Anthropic) ─────────────────────────────────────────────
# Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6

# ── Provider: Gemini (Google) ─────────────────────────────────────────────────
# Get free key at: https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# ── Provider: Ollama (Local / Free) ───────────────────────────────────────────
# Install: https://ollama.ai  |  then: ollama pull codellama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=codellama

# ── Default provider ─────────────────────────────────────────────────────────
# Which provider to use if the frontend doesn't specify one
# DEFAULT_PROVIDER=claude

# Optional: Server settings
# HOST=0.0.0.0
# PORT=8000
# DEBUG=false

# Optional: CORS (comma-separated list as JSON array)
# CORS_ORIGINS=["http://localhost:3000"]

# Optional: Database (defaults to SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./backend/storage/claude3d.db

# Optional: Worker concurrency
# WORKER_CONCURRENCY=2
